# ============================================================
# ScANN — LLM / AI 分析配置模板
# 复制此文件为 .env 并填入你的实际配置。
#   cp .env.example .env
# ============================================================

# LLM Provider：siliconflow / openai / openai_compatible / local
SCANN_LLM_PROVIDER=siliconflow

# Chat Completions 接口地址（可选；留空时按 Provider 使用默认地址）
# siliconflow: https://api.siliconflow.cn/v1/chat/completions
# openai: https://api.openai.com/v1/chat/completions
# local: http://127.0.0.1:11434/v1/chat/completions
SCANN_LLM_API_URL=

# API Key（必填，否则 AI 分析不可用）
SCANN_LLM_API_KEY=在此填入你的API密钥

# 模型名称（可选；留空时按 Provider 使用默认模型）
SCANN_LLM_MODEL=

# 是否默认开启 Qwen3 思考模式（true / false）
SCANN_LLM_ENABLE_THINKING=false

# 请求超时时间（秒）
SCANN_LLM_TIMEOUT_SECONDS=90

# 最大生成 Token 数
SCANN_LLM_MAX_TOKENS=600

# 生成温度（0-1，越低越确定）
SCANN_LLM_TEMPERATURE=0.2

# 纳入 Prompt 的最大 Top-K 命中数
SCANN_LLM_MAX_HITS_FOR_PROMPT=50

# 失败重试次数；默认最多重试 3 次，指数退避 1s/2s/4s
SCANN_LLM_RETRY_COUNT=3
SCANN_LLM_RETRY_BACKOFF_SECONDS=1

# 相同检索结果 + 相同问题的短期内存缓存
SCANN_LLM_CACHE_TTL_SECONDS=300
SCANN_LLM_CACHE_MAX_ENTRIES=128
